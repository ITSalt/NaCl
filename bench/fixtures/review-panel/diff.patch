+import { OrderService } from './order.service';
+
+describe('OrderService', () => {
+  const rows = [{ id: 'o1', createdAt: '2026-01-01' }];
+  const db = { query: jest.fn().mockResolvedValue(rows) };
+  const svc = new OrderService(db as any);
+
+  it('returns an order by id', async () => {
+    const o = await svc.getOrderById('o1');
+    expect(o).toEqual(rows[0]);
+  });
+
+  it('lists orders with a default limit', async () => {
+    await svc.listOrders();
+    expect(db.query).toHaveBeenCalledWith(
+      expect.stringContaining('LIMIT $1'),
+      [50],
+    );
+  });
+
+  it('computes the total of line items', () => {
+    const total = svc.computeTotal([
+      { price: 10, qty: 2 },
+      { price: 5, qty: 1 },
+    ]);
+    expect(total).toBe(25);
+  });
+});

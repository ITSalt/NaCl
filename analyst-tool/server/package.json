{
  "name": "analyst-tool-server",
  "version": "0.2.0",
  "description": "Fastify backend for the NaCl Analyst Tool",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NACL_DEV=true tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test src/services/*.test.ts src/*.test.ts src/routes/*.test.ts src/render/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "chokidar": "^3.6.0",
    "fastify": "^4.28.1",
    "itsalt-pinch": "^0.1.3",
    "neo4j-driver": "^5.27.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}

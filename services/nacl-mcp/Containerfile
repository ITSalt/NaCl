ARG NODE_IMAGE=node@sha256:09e2b3d9726018aecf269bd35325f46bf75046a643a66d28360ec71132750ec8

FROM ${NODE_IMAGE} AS dependencies
WORKDIR /opt/nacl/services/nacl-mcp
COPY services/nacl-mcp/package.json services/nacl-mcp/package-lock.json ./
RUN npm ci --omit=dev --ignore-scripts \
    && npm cache clean --force

FROM ${NODE_IMAGE} AS runtime
ARG SOURCE_DIGEST
ARG ARCHIVE_DIGEST
LABEL org.opencontainers.image.title="NaCl public MCP" \
      org.opencontainers.image.source-digest="${SOURCE_DIGEST}" \
      org.opencontainers.image.archive-digest="${ARCHIVE_DIGEST}"
WORKDIR /opt/nacl
COPY --from=dependencies --chown=node:node /opt/nacl/services/nacl-mcp/node_modules ./services/nacl-mcp/node_modules
COPY --chown=node:node services/nacl-mcp/package.json services/nacl-mcp/package-lock.json services/nacl-mcp/README.md ./services/nacl-mcp/
COPY --chown=node:node services/nacl-mcp/src ./services/nacl-mcp/src
COPY --chown=node:node codex-plugin-src/package/runtime/graph-gateway/authorization.mjs \
     codex-plugin-src/package/runtime/graph-gateway/errors.mjs \
     codex-plugin-src/package/runtime/graph-gateway/identity.mjs \
     codex-plugin-src/package/runtime/graph-gateway/server-operation-authorization.mjs \
     ./codex-plugin-src/package/runtime/graph-gateway/
COPY --chown=node:node LICENSE ./LICENSE
ENV NODE_ENV=production \
    NACL_MCP_HEALTH_URL=http://127.0.0.1:8080/healthz
USER node
EXPOSE 8080
HEALTHCHECK --interval=5s --timeout=3s --start-period=5s --retries=6 \
  CMD ["node", "-e", "fetch(process.env.NACL_MCP_HEALTH_URL).then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"]
ENTRYPOINT ["node", "/opt/nacl/services/nacl-mcp/src/entrypoint.mjs"]

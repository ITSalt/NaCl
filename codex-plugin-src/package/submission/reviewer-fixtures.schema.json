{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ITSalt/NaCl/blob/main/codex-plugin-src/package/submission/reviewer-fixtures.schema.json",
  "title": "NaCl plugin reviewer fixture set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "fixtureSetVersion",
    "status",
    "executionEvidence",
    "seed",
    "positive",
    "negative"
  ],
  "properties": {
    "$schema": { "const": "./reviewer-fixtures.schema.json" },
    "schemaVersion": { "const": 1 },
    "fixtureSetVersion": { "const": "nacl-reviewer-fixtures-v1" },
    "status": { "const": "LOCAL_CONTRACT_ONLY" },
    "executionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["localSimulation", "liveReviewer"],
      "properties": {
        "localSimulation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "scope"],
          "properties": {
            "status": { "const": "VERIFIED_CONTRACT_ONLY" },
            "scope": { "type": "string", "minLength": 20 }
          }
        },
        "liveReviewer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reason"],
          "properties": {
            "status": { "const": "NOT_RUN" },
            "reason": { "type": "string", "minLength": 20 }
          }
        }
      }
    },
    "seed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "status", "projects", "actors", "authorization", "backup"],
      "properties": {
        "version": { "const": "nacl-reviewer-seed-v1" },
        "status": { "const": "LOCAL_SIMULATION_ONLY" },
        "projects": { "type": "array", "minItems": 3, "maxItems": 3 },
        "actors": { "type": "array", "minItems": 2, "maxItems": 2 },
        "authorization": { "type": "array", "minItems": 2, "maxItems": 2 },
        "backup": { "type": "object" }
      }
    },
    "positive": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/positiveCase" }
    },
    "negative": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/negativeCase" }
    }
  },
  "$defs": {
    "toolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "scope", "arguments"],
      "properties": {
        "tool": { "type": "string", "pattern": "^nacl_[a-z_]+$" },
        "scope": { "type": "string", "pattern": "^nacl\\.server\\.(read|write|schema|backup|restore)$" },
        "confirmation": { "type": ["string", "null"] },
        "arguments": { "type": "object" }
      }
    },
    "expectedToolResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "result"],
      "properties": {
        "tool": { "type": "string", "pattern": "^nacl_[a-z_]+$" },
        "result": {
          "type": "object",
          "description": "Exact structured result validated against the referenced public tool output schema."
        }
      }
    },
    "positiveCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt", "toolCalls", "expectedBehavior", "expectedToolResults", "requiredSeed"],
      "properties": {
        "id": { "type": "string", "pattern": "^P[1-5]$" },
        "prompt": { "type": "string", "minLength": 20, "maxLength": 240 },
        "toolCalls": { "type": "array", "minItems": 1, "maxItems": 2, "items": { "$ref": "#/$defs/toolCall" } },
        "expectedBehavior": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } },
        "expectedToolResults": { "type": "array", "minItems": 1, "maxItems": 2, "items": { "$ref": "#/$defs/expectedToolResult" } },
        "requiredSeed": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } }
      }
    },
    "negativeCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scenario", "attemptedTool", "requiredScope", "prohibitedReason"],
      "oneOf": [
        { "required": ["expectedTransportRejection", "expectedSessionReauthorization"] },
        { "required": ["expectedMcpDenial"] },
        { "required": ["expectedRefusal"] }
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^N[1-3]$" },
        "scenario": { "type": "string", "minLength": 20, "maxLength": 320 },
        "attemptedTool": { "type": ["string", "null"] },
        "requiredScope": { "type": ["string", "null"] },
        "expectedTransportRejection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cases", "wireHttpStatus", "body", "wwwAuthenticate", "mcpResult", "graphCall", "internalAuditCode", "safeBehavior"],
          "properties": {
            "cases": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "enum": ["missing", "expired", "wrong-audience"] } },
            "wireHttpStatus": { "const": 401 },
            "body": { "const": "EMPTY" },
            "wwwAuthenticate": { "$ref": "#/$defs/transportChallenge" },
            "mcpResult": { "const": null },
            "graphCall": { "const": false },
            "internalAuditCode": { "const": "INVALID_TOKEN" },
            "safeBehavior": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } }
          }
        },
        "expectedSessionReauthorization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cases", "wireHttpStatus", "isError", "expectedMcpResults", "wwwAuthenticate", "graphCall", "safeBehavior"],
          "properties": {
            "cases": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "enum": ["stale-rotation", "revoked-session"] } },
            "wireHttpStatus": { "const": 200 },
            "isError": { "const": true },
            "expectedMcpResults": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["case", "structuredContent"],
                "properties": {
                  "case": { "enum": ["stale-rotation", "revoked-session"] },
                  "structuredContent": { "type": "object" }
                }
              }
            },
            "wwwAuthenticate": { "$ref": "#/$defs/toolChallenge" },
            "graphCall": { "const": false },
            "safeBehavior": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } }
          }
        },
        "expectedMcpDenial": {
          "type": "object",
          "additionalProperties": false,
          "required": ["wireHttpStatus", "applicationHttpStatus", "isError", "structuredContent", "wwwAuthenticate", "graphCall", "safeBehavior"],
          "properties": {
            "wireHttpStatus": { "const": 200 },
            "applicationHttpStatus": { "const": 403 },
            "isError": { "const": true },
            "structuredContent": { "type": "object" },
            "wwwAuthenticate": { "const": null },
            "graphCall": { "const": false },
            "safeBehavior": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } }
          }
        },
        "expectedRefusal": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "toolCallCount", "mcpResult", "graphCall", "safeBehavior"],
          "properties": {
            "mode": { "const": "CONVERSATIONAL_NO_TOOL_CALL" },
            "toolCallCount": { "const": 0 },
            "mcpResult": { "const": null },
            "graphCall": { "const": false },
            "safeBehavior": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } }
          }
        },
        "prohibitedReason": { "type": "string", "minLength": 20 }
      }
    },
    "transportChallenge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "resourceMetadata", "scope"],
      "properties": {
        "scheme": { "const": "Bearer" },
        "resourceMetadata": { "const": "RUNTIME_PROTECTED_RESOURCE_METADATA_URL" },
        "scope": { "type": "string", "pattern": "^nacl\\.server\\.(read|write|schema|backup|restore)$" }
      }
    },
    "toolChallenge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "resourceMetadata", "error", "errorDescription", "scope"],
      "properties": {
        "scheme": { "const": "Bearer" },
        "resourceMetadata": { "const": "RUNTIME_PROTECTED_RESOURCE_METADATA_URL" },
        "error": { "const": "invalid_token" },
        "errorDescription": { "const": "Authorization is required for this capability." },
        "scope": { "type": "string", "pattern": "^nacl\\.server\\.(read|write|schema|backup|restore)$" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ITSalt/NaCl/blob/main/codex-plugin-src/package/submission/reviewer-fixtures.schema.json",
  "title": "NaCl Skills-only reviewer fixture set",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "fixtureSetVersion", "status", "submissionType", "executionEvidence", "positive", "negative"],
  "properties": {
    "$schema": { "const": "./reviewer-fixtures.schema.json" },
    "schemaVersion": { "const": 2 },
    "fixtureSetVersion": { "const": "nacl-skills-only-reviewer-fixtures-v1" },
    "status": { "const": "LOCAL_CONTRACT_ONLY" },
    "submissionType": { "const": "SKILLS_ONLY" },
    "executionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["localSimulation", "liveReviewer"],
      "properties": {
        "localSimulation": { "$ref": "#/$defs/evidence" },
        "liveReviewer": { "$ref": "#/$defs/evidence" }
      }
    },
    "positive": { "type": "array", "minItems": 5, "maxItems": 5, "items": { "$ref": "#/$defs/positive" } },
    "negative": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "$ref": "#/$defs/negative" } }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "enum": ["VERIFIED_CONTRACT_ONLY", "NOT_RUN"] },
        "scope": { "type": "string", "minLength": 20 },
        "reason": { "type": "string", "minLength": 20 }
      }
    },
    "positive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt", "entrySkill", "precondition", "localEvidence", "expectedBehavior", "expectedStatus"],
      "properties": {
        "id": { "type": "string", "pattern": "^P[1-5]$" },
        "prompt": { "type": "string", "minLength": 20, "maxLength": 300 },
        "entrySkill": { "type": "string", "pattern": "^nacl-[a-z-]+$" },
        "precondition": { "type": "string", "minLength": 10 },
        "localEvidence": { "$ref": "#/$defs/localEvidence" },
        "expectedBehavior": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } },
        "expectedStatus": { "enum": ["VERIFIED", "NOT_RUN"] }
      }
    },
    "negative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scenario", "entrySkill", "localEvidence", "expectedBehavior", "expectedStatus", "expectedCode"],
      "properties": {
        "id": { "type": "string", "pattern": "^N[1-3]$" },
        "scenario": { "type": "string", "minLength": 20 },
        "entrySkill": { "type": "string", "pattern": "^nacl-[a-z-]+$" },
        "localEvidence": { "$ref": "#/$defs/localEvidence" },
        "expectedBehavior": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 10 } },
        "expectedStatus": { "const": "BLOCKED" },
        "expectedCode": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "expectedCodes": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" } }
      }
    },
    "localEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "test", "scope"],
      "properties": {
        "status": { "enum": ["VERIFIED", "VERIFIED_CONTRACT_ONLY", "NOT_RUN"] },
        "test": { "type": "string", "minLength": 10 },
        "scope": { "type": "string", "minLength": 20 }
      }
    }
  }
}

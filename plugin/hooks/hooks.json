{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/nacl-core/scripts/graph-doctor.mjs\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/check-coexistence.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

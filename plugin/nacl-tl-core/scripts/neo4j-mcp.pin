# neo4j-mcp.pin — version pin + sha256 checksums for the official neo4j-mcp binary release.
#
# Consumed by setup-graph.sh / setup-graph.ps1 / lib-neo4j-mcp.sh / lib-neo4j-mcp.ps1
# (resolved relative to the calling script's own directory — this file must stay
# next to them). Format: plain `key=value` lines, `#` comments allowed.
#
# To bump: fetch https://api.github.com/repos/neo4j/mcp/releases/latest, take
# tag_name as `version`, download the release's `*_checksums.txt` asset and copy
# the sha256 values below (asset filenames use Darwin/Linux/Windows + x86_64/arm64/i386,
# this file uses lowercase os_arch keys).
#
# NaCl's own infra pin (not a project-facing template) — out of scope for
# scripts/check-version-pins.sh, see that script's header.

version=v1.5.3

sha256_darwin_arm64=c1cb18a6ee30e8ac129868ca2d7f8889d5101dbd0340f22f9d5b9e02cfef6e66
